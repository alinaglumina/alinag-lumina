# ─── Core ───────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:4000

# ─── Database (MongoDB Atlas) ───────────────────────────
# Atlas → Connect → Drivers → copy the SRV string; whitelist your IP.
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/lumina?retryWrites=true&w=majority

# ─── Auth / JWT ─────────────────────────────────────────
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_DOMAIN=localhost

# ─── Google OAuth ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ─── Payments (Razorpay) ────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Email (SMTP) ───────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="Alinag Lumina <no-reply@alinaglumina.com>"

# ─── Media (Cloudinary) ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_SECRET=

# ─── Cache / Sessions (Redis) ───────────────────────────
REDIS_URL=redis://localhost:6379

# ─── SMS / Push (optional) ──────────────────────────────
SMS_PROVIDER_KEY=
FCM_SERVER_KEY=

# ─── Logistics (order tracking) ─────────────────────────
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# ─── Frontend public ────────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_RAZORPAY_KEY_ID=
